# ============================================
# ISOLATED TEMPORARY HOME
# ============================================
export GHOST_ORIGINAL_HOME="$HOME"
export GHOST_SESSION_ID="$$"
export GHOST_TEMP_HOME="/tmp/ghost_home_${GHOST_SESSION_ID}"

mkdir -p "$GHOST_TEMP_HOME"

# Try to mount tmpfs (RAM disk) - 200M
if mount -t tmpfs -o size=200M,mode=700,nosuid,nodev tmpfs "$GHOST_TEMP_HOME" 2>/dev/null; then
    export GHOST_HOME_TYPE="tmpfs"
else
    export GHOST_HOME_TYPE="regular"
fi

export HOME="$GHOST_TEMP_HOME"
export GHOST_HOME="$GHOST_TEMP_HOME"

# Create standard home directory structure
mkdir -p "$HOME/.config" "$HOME/.cache" "$HOME/.local/share" "$HOME/.local/bin"
mkdir -p "$HOME/Downloads" "$HOME/Documents"

# Create minimal shell profile (suppress history, etc.)
cat > "$HOME/.profile" << 'PROFILE_EOF'
# Ghost Secure Shell Profile
export EDITOR=nano
export VISUAL=nano
export PAGER=less
export HISTFILE=/dev/null
export HISTSIZE=0
export LESSHISTFILE=/dev/null
PROFILE_EOF

# ============================================
# SECURITY EXECUTION CHAIN
# ============================================
# Build the security wrapper chain: Seccomp -> Landlock -> Caps -> Shell
SHELL_EXEC="export PS1='\[\033[0;31m\][ghost]\[\033[0m\] \w\\\$ '; export PROMPT_COMMAND='touch /dev/shm/ghost_heartbeat 2>/dev/null'; exec bash --rcfile $ghost_rc"

CMD_CHAIN=("bash" "$DIR/lib/caps.sh" "$REAL_USER" "$SHELL_EXEC")

# Add Landlock if available
if [[ -x "$DIR/lib/apply_landlock" ]]; then
    CMD_CHAIN=("$DIR/lib/apply_landlock" "${CMD_CHAIN[@]}")
fi

# Add Seccomp (MANDATORY - fail if missing)
if [[ -x "$DIR/lib/apply_seccomp" ]]; then
    CMD_CHAIN=("$DIR/lib/apply_seccomp" "${CMD_CHAIN[@]}")
else
    echo -e "\033[0;31m[FATAL] Security Critical Error\033[0m" >&2
    echo "  lib/apply_seccomp is missing or not executable" >&2
    echo "  Ghost requires Seccomp-BPF to block raw sockets" >&2
    exit 1
fi

# Verify caps.sh exists
if [[ ! -f "$DIR/lib/caps.sh" ]]; then
    echo -e "\033[0;31m[FATAL] Security Critical Error\033[0m" >&2
    echo "  lib/caps.sh is missing" >&2
    exit 1
fi

# ============================================
# CLEANUP ON EXIT
# ============================================
cleanup_ghost_session() {
    umount /proc/cpuinfo 2>/dev/null || true
    umount /proc/meminfo 2>/dev/null || true
    umount /proc/version 2>/dev/null || true
    umount /proc/loadavg 2>/dev/null || true
    umount /proc/uptime 2>/dev/null || true
    rm -f /tmp/.ghost_cpuinfo_$$ /tmp/.ghost_meminfo_$$ 2>/dev/null || true
    rm -f /tmp/.ghost_version_$$ /tmp/.ghost_loadavg_$$ /tmp/.ghost_uptime_$$ 2>/dev/null || true
    
    if [[ "$GHOST_HOME_TYPE" == "tmpfs" ]]; then
        umount "$GHOST_TEMP_HOME" 2>/dev/null || true
    fi
    
    rm -rf "$GHOST_TEMP_HOME" 2>/dev/null || true
    rm -f /dev/shm/ghost_heartbeat_$$ 2>/dev/null || true
}

trap cleanup_ghost_session EXIT INT TERM

# ============================================
# EXECUTE SECURITY CHAIN
# ============================================
exec "${CMD_CHAIN[@]}"
EOF
    chmod +x "$ghost_init"

    # Strict Isolation Check
    # [FIX 1.5] Added --time namespace to allow date -s (jitter)
    local isolation_cmd="unshare --ipc --pid --mount-proc --fork --mount --user --map-root-user --uts --time"
    
    if ! command -v unshare &>/dev/null; then
         stty "$term_settings" 2>/dev/null
         echo -e "\n  ${RED}Error: 'unshare' utility missing.${NC}"
         read -r -n 1
         eval "$old_traps"
         return 0
    fi

    # Check for namespace support (including --time if possible)
    if ! unshare --ipc --pid --mount-proc --fork --mount --user --map-root-user --uts --time true 2>/dev/null; then
         # Fallback without --time if kernel < 5.6
         if ! unshare --ipc --pid --mount-proc --fork --mount --user --map-root-user --uts true 2>/dev/null; then
             stty "$term_settings" 2>/dev/null
             ui_clear_content
             echo ""
             echo -e "  ${RED}${BOLD}ERROR: Isolation Failed${NC}"
             echo ""
             echo -e "  ${DIM}Kernel missing namespace support.${NC}"
             echo -e "  ${DIM}Cannot create secure sandbox.${NC}"
             echo ""
             echo -e "  ${DIM}[Press any key to return]${NC}"
             read -r -n 1
             eval "$old_traps"
             return 0
         else
             # Remove --time from command if not supported
             isolation_cmd="unshare --ipc --pid --mount-proc --fork --mount --user --map-root-user --uts"
         fi
    fi
    
    local err_file
    err_file=$(mktemp)
    
    if ! ip netns exec ghost $isolation_cmd script -q -c "$ghost_init" /dev/null 2> "$err_file"; then
        stty "$term_settings" 2>/dev/null
        
        printf "\033[?25l"
        ui_refresh
        
        ui_clear_content
        echo ""
        echo -e "  ${RED}${BOLD}ERROR: Shell Launch Failed${NC}"
        echo ""
        ui_divider
        echo ""
        if [[ -s "$err_file" ]]; then
            sed 's/^/  /' "$err_file"
        else
            echo -e "  ${DIM}(No error message captured)${NC}"
        fi
        echo ""
        ui_divider
        echo ""
        echo -e "  ${DIM}[Press any key to return]${NC}"
        read -r -n 1
    fi
    rm -f "$err_file" "$ghost_rc" "$ghost_init"
    
    stty "$term_settings" 2>/dev/null
    
    # [FIX 15.1] Restore global traps
    eval "$old_traps"
    
    ui_init
    ui_refresh
    return 0
}

cmd_test() {
    if ! check_ghost; then
        ui_clear_content
        echo ""
        echo -e "  ${RED}Ghost not running${NC}"
        echo ""
        echo -e "  ${DIM}[Press any key to return]${NC}"
        read -r -n 1
        return
    fi
    
    ui_clear_content
    echo ""
    echo -e "  ${BOLD}SECURITY AUDIT${NC}"
    echo ""
    ui_divider
    echo ""
    
    local tests_passed=0
    local tests_total=5
    
    echo -ne "  Tor Connectivity          "
    local exit_ip
    exit_ip=$(get_exit_ip)
    if [[ -n "$exit_ip" ]]; then
        echo -e "${GREEN}[PASS]${NC}"
        echo -e "  ${DIM}└─ Exit: $exit_ip${NC}"
        tests_passed=$((tests_passed + 1))
    else
        echo -e "${RED}[FAIL]${NC}"
        echo -e "  ${DIM}└─ Cannot reach Tor network${NC}"
    fi
    echo ""
    
    echo -ne "  Kill Switch (ICMP)        "
    if ! ip netns exec ghost ping -c1 -W1 1.1.1.1 &>/dev/null; then
        echo -e "${GREEN}[PASS]${NC}"
        echo -e "  ${DIM}└─ ICMP blocked correctly${NC}"
        tests_passed=$((tests_passed + 1))
    else
        echo -e "${RED}[FAIL]${NC}"
        echo -e "  ${DIM}└─ ICMP leak detected!${NC}"
    fi
    echo ""
    
    echo -ne "  DNS Configuration         "
    local dns_server
    dns_server=$(ip netns exec ghost cat /etc/resolv.conf 2>/dev/null | grep nameserver | awk '{print $2}')
    if [[ "$dns_server" == "10.200.200.1" ]]; then
        echo -e "${GREEN}[PASS]${NC}"
        echo -e "  ${DIM}└─ DNS via Tor resolver${NC}"
        tests_passed=$((tests_passed + 1))
    else
        echo -e "${YELLOW}[WARN]${NC}"
        echo -e "  ${DIM}└─ DNS: $dns_server${NC}"
    fi
    echo ""
    
    echo -ne "  DNS Resolution            "
    local dns_start dns_end dns_time
    dns_start=$(date +%s%N)
    if ip netns exec ghost su $REAL_USER -c "curl -s --connect-timeout 5 -o /dev/null https://check.torproject.org" 2>/dev/null; then
        dns_end=$(date +%s%N)
        dns_time=$(( (dns_end - dns_start) / 1000000 ))
        echo -e "${GREEN}[PASS]${NC}"
        echo -e "  ${DIM}└─ ${dns_time}ms via Tor${NC}"
        tests_passed=$((tests_passed + 1))
    else
        echo -e "${RED}[FAIL]${NC}"
        echo -e "  ${DIM}└─ DNS resolution failed${NC}"
    fi
    echo ""
    
    echo -ne "  TLS Certificate           "
    local cert_issuer
    cert_issuer=$(echo | timeout 5 openssl s_client -connect check.torproject.org:443 2>/dev/null | openssl x509 -noout -issuer 2>/dev/null | head -1)
    if [[ -n "$cert_issuer" ]] && ! echo "$cert_issuer" | grep -qiE "localhost|self.signed|mitmproxy"; then
        echo -e "${GREEN}[PASS]${NC}"
        echo -e "  ${DIM}└─ Valid certificate chain${NC}"
        tests_passed=$((tests_passed + 1))
    else
        echo -e "${YELLOW}[WARN]${NC}"
        echo -e "  ${DIM}└─ Unable to verify issuer${NC}"
    fi
    echo ""
    
    ui_divider
    echo ""
    
    if [[ $tests_passed -eq $tests_total ]]; then
        echo -e "  ${GREEN}${BOLD}OVERALL: SECURE${NC}"
        echo ""
        echo -e "  ${DIM}All checks passed. You are invisible.${NC}"
    elif [[ $tests_passed -ge 3 ]]; then
        echo -e "  ${YELLOW}${BOLD}OVERALL: WARNINGS${NC}"
        echo ""
        echo -e "  ${DIM}$tests_passed/$tests_total checks passed.${NC}"
    else
        echo -e "  ${RED}${BOLD}OVERALL: ISSUES DETECTED${NC}"
        echo ""
        echo -e "  ${DIM}Only $tests_passed/$tests_total checks passed.${NC}"
    fi
    
    echo ""
    ui_divider
    echo ""
    echo -e "  ${GREEN}[1]${NC} Run Again    ${CYAN}[2]${NC} Enter Shell    ${DIM}[0]${NC} Back"
    echo ""
    echo -n "  Select: "
    
    read -r choice
    case "$choice" in
        1) cmd_test ;;
        2) cmd_shell ;;
    esac
}

cmd_identity() {
    if ! check_ghost; then
        ui_clear_content
        echo ""
        echo -e "  ${RED}Ghost not running${NC}"
        echo ""
        echo -e "  ${DIM}[Press any key to return]${NC}"
        read -r -n 1
        return
    fi
    
    ui_clear_content
    echo ""
    echo -e "  ${BOLD}NEW IDENTITY${NC}"
    echo ""
    ui_divider
    echo ""
    
    state_read
    local old_ip="$exit_ip"
    echo -e "  ${DIM}Current exit: $old_ip${NC}"
    echo ""
    
    local attempts=0 max_attempts=3 new_ip
    
    while [[ $attempts -lt $max_attempts ]]; do
        attempts=$((attempts + 1))
        
        ui_clear_content
        echo ""
        echo -e "  ${BOLD}NEW IDENTITY${NC}"
        echo ""
        ui_divider
        echo ""
        echo -e "  ${DIM}Current exit: $old_ip${NC}"
        echo ""
        
        echo -ne "  [1/3] Sending NEWNYM signal... "
        
        local auth_cmd
        auth_cmd=$(get_tor_auth)
        
        if [[ -n "$auth_cmd" ]] && ( echo -e "$auth_cmd\r\nSIGNAL NEWNYM\r\nQUIT" > /dev/tcp/127.0.0.1/9051 ) 2>/dev/null; then
            :
        else
            killall -HUP tor 2>/dev/null || true
        fi
        echo -e "${GREEN}OK${NC}"
        
        echo -ne "  [2/3] Building new circuit... "
        
        if wait_for_connection 45; then
            echo -e "${GREEN}OK${NC}"
            new_ip=$(get_exit_ip)
        else
            echo -e "${RED}TIMEOUT${NC}"
        fi
        
        echo -ne "  [3/3] Verifying connectivity... "
        if [[ -n "$new_ip" && "$new_ip" != "$old_ip" ]]; then
            echo -e "${GREEN}OK${NC}"
            update_state "$new_ip"
            
            ui_clear_content
            echo ""
            echo -e "  ${GREEN}${BOLD}IDENTITY CHANGED${NC}"
            echo ""
            ui_divider
            echo ""
            echo -e "  ${DIM}Old IP: $old_ip${NC}"
            echo -e "  ${DIM}New IP: $new_ip${NC}"
            echo ""
            ui_divider
            echo ""
            
            state_read
            ui_status_line "New exit" "$exit_ip" "$GREEN"
            ui_status_line "Location" "$exit_country" "$CYAN"
            
            echo ""
            echo -e "  ${DIM}[Press any key to continue]${NC}"
            read -r -n 1
            return
        fi
        echo -e "${RED}RETRYING${NC}"
        
        if [[ $attempts -lt $max_attempts ]]; then
            echo ""
            echo -e "  ${YELLOW}Same exit, retrying...${NC}"
            sleep 1
        fi
    done
    
    ui_clear_content
    echo ""
    echo -e "  ${YELLOW}${BOLD}SAME EXIT NODE${NC}"
    echo ""
    ui_divider
    echo ""
    echo -e "  ${DIM}Exit IP: $new_ip${NC}"
    echo ""
    echo -e "  ${DIM}This is rare but normal. Your circuit${NC}"
    echo -e "  ${DIM}path (Guard → Middle) likely changed.${NC}"
    echo ""
    echo -e "  ${DIM}[Press any key to continue]${NC}"
    read -r -n 1
}

cmd_country() {
    ui_clear_content
    echo ""
    echo -e "  ${BOLD}SET EXIT NODE COUNTRY${NC}"
    echo ""
    ui_divider
    echo ""
    
    state_read
    if [[ -n "$exit_country" ]]; then
        echo -e "  ${DIM}Current: $exit_country${NC}"
    else
        echo -e "  ${DIM}Current: Random (Global)${NC}"
    fi
    echo ""
    
    echo -e "  ${BOLD}AVAILABLE REGIONS${NC}"
    echo ""
    
    ui_menu_item "1" "United States (us)" "Best for US-target testing"
    ui_menu_item "2" "Germany (de)" "Strong privacy laws"
    ui_menu_item "3" "Netherlands (nl)" "High bandwidth exits"
    ui_menu_item "4" "Switzerland (ch)" "Neutral jurisdiction"
    ui_menu_item "5" "France (fr)" "EU location variety"
    ui_menu_item "6" "Canada (ca)" "North America alternative"
    ui_menu_item "7" "United Kingdom (uk)" "English language exits"
    
    echo -e "  ${DIM}[0]${NC} Cancel"
    echo ""
    ui_divider
    echo ""
    echo -n "  Select: "
    
    read -r choice
    
    local country_code=""
    case "$choice" in
        1) country_code="us" ;;
        2) country_code="de" ;;
        3) country_code="nl" ;;
        4) country_code="ch" ;;
        5) country_code="fr" ;;
        6) country_code="ca" ;;
        7) country_code="uk" ;;
        0|*) return ;;
    esac
    
    echo -e "  ${DIM}Setting exit country to $country_code...${NC}"
    
    echo -e "  ${DIM}Setting exit country to $country_code...${NC}"
    
    # [FIX 17.1] Use internal Tor instance ONLY. Do not touch /etc/tor/torrc.
    if ! bash "$DIR/lib/tor.sh" country "$country_code"; then
        echo -e "${RED}Error: Failed to set country via lib/tor.sh${NC}"
        read -r -n 1
        return
    fi
    
    # tor.sh restarts the instance, so we just wait for new circuit
    local new_config="" # variable not needed but kept for cleanup if referenced later, though logic changed
    
    echo -e "  ${DIM}Waiting for new circuit...${NC}"
    
    # Trigger circuit rotation to use new config
    local auth_cmd
    auth_cmd=$(get_tor_auth)
    if [[ -n "$auth_cmd" ]]; then
         ( echo -e "$auth_cmd\r\nSIGNAL NEWNYM\r\nQUIT" > /dev/tcp/127.0.0.1/9051 ) 2>/dev/null
    else
         killall -HUP tor 2>/dev/null
    fi
    
    local retries=15
    local success=0
    local new_ip=""
    
    for ((i=1; i<=retries; i++)); do
        echo -ne "\r  ${DIM}Verifying location ($i/$retries)...${NC}"
        
        # Wait for circuit
        sleep 3
        
        new_ip=$(get_exit_ip)
        local country_info
        country_info=$(get_exit_country "$new_ip")
        
        # Check if country matches the requested code (case insensitive)
        if [[ -n "$country_info" ]] && echo "$country_info" | grep -qi "$country_code"; then
             success=1
             break
        fi
        
        # Retry NEWNYM if stuck halfway
        if [[ $i -eq 5 || $i -eq 10 ]]; then
             if [[ -n "$auth_cmd" ]]; then
                  ( echo -e "$auth_cmd\r\nSIGNAL NEWNYM\r\nQUIT" > /dev/tcp/127.0.0.1/9051 ) 2>/dev/null
             fi
        fi
    done
    echo ""
    
    if [[ $success -eq 0 ]]; then
         echo -e "  ${YELLOW}Warning: Target country not yet active.${NC}"
         echo -e "  ${DIM}Tor is still building circuits. Please wait.${NC}"
    fi
    
    update_state "$new_ip"
    
    ui_clear_content
    echo ""
    echo -e "  ${GREEN}${BOLD}COUNTRY SET${NC}"
    echo ""
    ui_divider
    echo ""
    
    state_read
    ui_status_line "Region" "${country_code^^}"
    ui_status_line "Exit IP" "$exit_ip" "$GREEN"
    ui_status_line "Location" "$exit_country" "$CYAN"
    
    echo ""
    echo -e "  ${DIM}[Press any key to continue]${NC}"
    read -r -n 1
}

