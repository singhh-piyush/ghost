    SESSION_KEY=$(openssl rand -hex 32 2>/dev/null || head -c 32 /dev/urandom | xxd -p -c 32)
    
    if [[ -z "$SESSION_KEY" ]]; then
        echo "[WARN] Failed to generate session encryption key" >&2
