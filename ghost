    if check_ghost; then
        echo -e "${GREEN}[ACTIVE]${NC}"
    else
        echo -e "${RED}[INACTIVE]${NC}"
        return
    fi
    
    echo -n "  Tor Connection      "
    if check_tor >/dev/null 2>&1; then
         echo -e "${GREEN}[CONNECTED]${NC}"
    else
         echo -e "${RED}[DISCONNECTED]${NC}"
    fi

    echo -n "  Current IP          "
    local current_ip
    if current_ip=$(get_exit_ip); then
        echo -e "${GREEN}$current_ip${NC}"
    else
        echo -e "${YELLOW}[UNKNOWN]${NC}"
    fi
}

cmd_status() {
    ui_clear_content
    echo ""
    echo -e "  ${BOLD}SYSTEM STATUS${NC}"
    echo ""
    
    check_status
    
    echo ""
    verify_stream_isolation
    echo ""
    
    # [FIX 7.2] Circuit Path Verification
    echo -e "  ${BOLD}Active Circuits:${NC}"
    if [[ -n "$auth_cmd" ]]; then
        local circuits
        circuits=$( (echo -e "$auth_cmd\r\nGETINFO circuit-status\r\nQUIT" | timeout 2 nc 127.0.0.1 9051 | grep "^250-") 2>/dev/null ) || true
        
        if [[ -n "$circuits" ]]; then
            while IFS= read -r result; do
                local id status path
                id=$(echo "$result" | awk '{print $1}' | cut -d- -f2) # 250-ID
                status=$(echo "$result" | awk '{print $2}')
                path=$(echo "$result" | cut -d' ' -f3-)
                
                if [[ "$status" == "BUILT" ]]; then
                    echo -e "  ${CYAN}Circuit $id:${NC} $path"
                fi
            done <<< "$circuits"
        else
             echo -e "  ${DIM}No circuit info available${NC}"
        fi
    else
        echo -e "  ${YELLOW}Cannot query circuits (No auth)${NC}"
    fi
    echo ""
    ui_divider
    echo ""
    
    echo -n "  Ghost Namespace     "
    if check_ghost; then
        echo -e "${GREEN}[ACTIVE]${NC}"
    else
        echo -e "${RED}[INACTIVE]${NC}"
    fi
    
    echo -n "  Tor Service         "
    if systemctl is-active --quiet tor; then
        echo -e "${GREEN}[RUNNING]${NC}"
    else
        echo -e "${RED}[STOPPED]${NC}"
    fi
    
    echo -n "  Connectivity        "
    if check_ghost; then
        if wait_for_connection 5; then
            echo -e "${GREEN}[ONLINE]${NC}"
        else
            echo -e "${RED}[OFFLINE]${NC}"
        fi
    else
        if curl -s --socks5-hostname 127.0.0.1:9050 --connect-timeout 5 https://check.torproject.org >/dev/null 2>&1; then
            echo -e "${GREEN}[ONLINE]${NC}"
        else
            echo -e "${RED}[OFFLINE]${NC}"
        fi
    fi
    
    echo ""
    
    if check_ghost; then
        ui_divider
        echo ""
        echo -e "  ${BOLD}CONNECTION${NC}"
        echo ""
        
        state_read
        ui_status_line "Exit IP" "$exit_ip" "$GREEN"
        ui_status_line "Location" "$exit_country" "$CYAN"
        ui_status_line "Uptime" "$(get_uptime)"
        ui_status_line "Circuit" "$(get_circuit_age)"
        

        
        echo ""
        echo -e "  ${YELLOW}[!] DNS LEAK WARNING:${NC} Ghost blocks standard DNS (53)."
        echo -e "      However, browsers with ${BOLD}DoH${NC} (DNS over HTTPS) enabled"
        echo -e "      may still bypass Tor. Disable DoH in browser settings."
        echo ""
        echo -n "  Auto-Heal           "
        if [[ -f "$AUTOHEAL_PID" ]] && kill -0 "$(cat "$AUTOHEAL_PID")" 2>/dev/null; then
            echo -e "${GREEN}[ENABLED]${NC}"
        else
            echo -e "${DIM}[DISABLED]${NC}"
        fi
    fi
    
    echo ""
    ui_divider
    echo ""
    echo -e "  ${DIM}[Press any key to return]${NC}"
    read -r -n 1
}

cmd_nuke() {
    if ! ui_confirm "EMERGENCY NUKE" "Force reset all Ghost components?"; then
        return
    fi
    
    echo -e "  ${RED}Nuking all Ghost components...${NC}"
    
