# [FIX 20.1] Lock Management
# Allow status/stop/shell/test to run concurrently (no lock needed)
# Only start/menu/setup-actions need exclusive lock

acquire_lock() {
    exec 200>/var/run/ghost.lock
    if ! flock -n 200; then
        echo -e "${RED}Ghost is already running!${NC}"
        echo -e "  ${DIM}• To enter the secure shell:${NC}   sudo ghost shell"
        echo -e "  ${DIM}• To stop the background process:${NC} sudo ghost stop"
        exit 1
    fi
    # Write PID for 'stop' command to target
    echo $$ > /var/run/ghost.pid
}

# [FIX] Cleanup lock/pid on exit
trap 'rm -f /var/run/ghost.lock /var/run/ghost.pid' EXIT INT TERM

case "${1:-}" in
