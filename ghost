cmd_stop() {
    if ! ui_confirm "STOP GHOST" "Destroy anonymous connection?"; then
        return 0
    fi
    
    ui_clear_content
    echo ""
    echo -e "  ${BOLD}STOPPING GHOST${NC}"
    echo ""
    
    # [FIX 20.2] Kill the background instance if running
    if [[ -f "/var/run/ghost.pid" ]]; then
        local pid
        pid=$(cat "/var/run/ghost.pid")
        if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
            echo -e "  ${DIM}Stopping background process ($pid)...${NC}"
            kill "$pid" 2>/dev/null || true
            # Wait for it to exit and clean up the lock
            sleep 1
            if kill -0 "$pid" 2>/dev/null; then
                kill -9 "$pid" 2>/dev/null || true
            fi
        fi
        rm -f "/var/run/ghost.pid"
    fi
    
    ui_divider
    echo ""
    
    if [[ -f "$STATE_FILE" ]]; then
        state_read
        local uptime
        uptime=$(get_uptime)
        
        echo -e "  ${DIM}Session Duration:${NC} $uptime"
        echo -e "  ${DIM}Identity Changes:${NC} $identity_changes"
        echo ""
    fi
    
    monitor_stop
    
    echo -e "  ${DIM}Cleaning up...${NC}"
    cleanup
    session_log "SESSION" "Ghost stopped"
    
    # [FIX 0.2] Ensure lock/pid files are cleaned up
    rm -f /var/run/ghost.lock
    rm -f /var/run/ghost.pid
    
    if check_ghost; then
        echo ""
        echo -e "  ${RED}WARNING: Namespace still exists${NC}"
        echo -e "  ${DIM}Applying forceful cleanup...${NC}"
        ip netns del ghost 2>/dev/null || true
    fi
    
    echo ""
    if ! check_ghost; then
        echo -e "  ${GREEN}Ghost stopped successfully${NC}"
    else
        echo -e "  ${RED}Failed to fully stop Ghost${NC}"
        echo -e "  ${DIM}Try: sudo ip netns del ghost${NC}"
    fi
    echo ""
    echo -e "  ${DIM}Status: VISIBLE - Real IP exposed${NC}"
    echo ""
    ui_divider
    echo ""
    echo -e "  ${DIM}[Press any key to continue]${NC}"
    
    printf "\033[?25h"
    read -r -n 1
    printf "\033[?25l"
}

