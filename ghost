# Helper function to get Tor info via control port
get_tor_info() {
    local command="$1"
    local auth
    auth=$(get_tor_auth)
    
    if [[ -z "$auth" ]]; then
        return 1
    fi
    
    {
        echo "$auth"
        echo "$command"
        echo "QUIT"
    } | nc 127.0.0.1 9051 2>/dev/null | grep -v "^250" | grep -v "^\."
}

