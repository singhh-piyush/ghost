# Ghost Health Check - diagnostic function
cmd_health_check() {
    clear
    echo -e "${BOLD}=== GHOST HEALTH CHECK ===${NC}"
    echo ""
    
    local issues=0
    local warnings=0
    
    # Check 1: Namespace
    echo -n "Checking namespace... "
    if ip netns list 2>/dev/null | grep -q "^ghost"; then
        echo -e "${GREEN}✓${NC}"
    else
        echo -e "${RED}✗ Not running${NC}"
        ((issues++))
    fi
    
    # Check 2: IPv6 leak
    echo -n "Checking IPv6 blocking... "
    local ipv6
    ipv6=$(ip netns exec ghost ip -6 addr 2>/dev/null | grep -c inet6 || echo 0)
    if [[ $ipv6 -eq 0 ]]; then
        echo -e "${GREEN}✓ Blocked${NC}"
    else
        echo -e "${RED}✗ LEAK ($ipv6 addresses)${NC}"
        ((issues++))
    fi
    
    # Check 3: Tor connectivity
    echo -n "Checking Tor... "
    if timeout 5 curl -s https://check.torproject.org/api/ip 2>/dev/null | grep -q '"IsTor":true'; then
        echo -e "${GREEN}✓ Connected${NC}"
    else
        echo -e "${YELLOW}⚠ Not responding${NC}"
        ((warnings++))
    fi
    
    # Check 4: DNS leak
    echo -n "Checking DNS... "
    local dns_leak
    dns_leak=$(ip netns exec ghost dig +short @8.8.8.8 google.com 2>&1 | grep -v "connection refused" | wc -l)
    if [[ $dns_leak -eq 0 ]]; then
        echo -e "${GREEN}✓ Isolated${NC}"
    else
        echo -e "${RED}✗ LEAK${NC}"
        ((issues++))
    fi
    
    # Check 5: Seccomp
    echo -n "Checking Seccomp... "
    if ip netns exec ghost cat /proc/self/status 2>/dev/null | grep -q "Seccomp:.*2"; then
        echo -e "${GREEN}✓ Active${NC}"
    else
        echo -e "${RED}✗ Inactive${NC}"
        ((issues++))
    fi
    
    # Check 6: Raw socket block
    echo -n "Checking raw socket blocking... "
    if ip netns exec ghost python3 -c "import socket; socket.socket(socket.AF_PACKET, socket.SOCK_RAW)" 2>&1 | grep -q "not permitted"; then
        echo -e "${GREEN}✓ Blocked${NC}"
    else
        echo -e "${RED}✗ NOT BLOCKED${NC}"
        ((issues++))
    fi
    
    # Check 7: Firewall rules
    echo -n "Checking firewall... "
    local rules
    rules=$(ip netns exec ghost iptables -L 2>/dev/null | grep -c "DROP" || echo 0)
    if [[ $rules -gt 5 ]]; then
        echo -e "${GREEN}✓ ${rules} rules${NC}"
    else
        echo -e "${YELLOW}⚠ Only ${rules} rules${NC}"
        ((warnings++))
    fi
    
    echo ""
    echo "──────────────────────────────"
    echo ""
    
    if [[ $issues -eq 0 && $warnings -eq 0 ]]; then
        echo -e "${GREEN}✓ All checks passed!${NC}"
    elif [[ $issues -eq 0 ]]; then
        echo -e "${YELLOW}⚠ ${warnings} warnings (non-critical)${NC}"
    else
        echo -e "${RED}✗ ${issues} critical issues found${NC}"
        echo ""
        echo "Run 'sudo ghost stop && sudo ghost start' to reset"
    fi
    
    echo ""
    read -r -n 1 -p "Press any key to continue..."
}

# Cover traffic generation to prevent traffic analysis
cmd_cover_traffic() {
    if ! check_ghost; then
        echo -e "${RED}Ghost is not running${NC}"
        return 1
    fi
    
    ui_clear_content
    echo ""
    echo -e "  ${BOLD}Cover Traffic Generator${NC}"
    echo ""
    echo -e "  ${DIM}Generates random HTTP/HTTPS traffic to obfuscate your${NC}"
    echo -e "  ${DIM}actual browsing patterns and prevent traffic analysis.${NC}"
    echo ""
    ui_divider
    echo ""
    
    read -r -p "  Duration in minutes (1-60): " duration
    
    if ! [[ "$duration" =~ ^[0-9]+$ ]] || [[ $duration -lt 1 ]] || [[ $duration -gt 60 ]]; then
        echo -e "  ${RED}Invalid duration${NC}"
        return 1
    fi
    
    echo ""
    echo -e "  ${GREEN}Starting cover traffic...${NC}"
    echo -e "  ${DIM}Duration: ${duration} minutes${NC}"
    echo ""
    
    # Create cover traffic script
    cat > /tmp/ghost_cover_traffic_$$ << 'COVER_EOF'
#!/bin/bash
DURATION=$1
END_TIME=$(($(date +%s) + DURATION * 60))

SITES=(
    "https://www.wikipedia.org/wiki/Special:Random"
    "https://www.reddit.com/r/all/"
    "https://news.ycombinator.com"
    "https://lobste.rs"
    "https://www.technologyreview.com"
    "https://arstechnica.com"
    "https://www.theguardian.com/international"
    "https://www.bbc.com/news"
    "https://www.reuters.com"
    "https://techcrunch.com"
)

echo "[$(date)] Cover traffic started"

while [[ $(date +%s) -lt $END_TIME ]]; do
    SITE="${SITES[$RANDOM % ${#SITES[@]}]}"
    DELAY=$((RANDOM % 110 + 10))
    curl -s --max-time 10 "$SITE" >/dev/null 2>&1
    echo "[$(date)] Fetched: $SITE (next in ${DELAY}s)"
    sleep $DELAY
done

echo "[$(date)] Cover traffic completed"
COVER_EOF
    
    chmod +x /tmp/ghost_cover_traffic_$$
    
    # Run in background within namespace
    ip netns exec ghost /tmp/ghost_cover_traffic_$$ "$duration" > "$RUNTIME_DIR/cover_traffic.log" 2>&1 &
    local pid=$!
    echo $pid > "$RUNTIME_DIR/cover_traffic.pid"
    
    echo -e "  ${GREEN}✓${NC} Cover traffic running (PID: $pid)"
    echo -e "  ${DIM}Log: $RUNTIME_DIR/cover_traffic.log${NC}"
    echo ""
    
    read -r -n 1 -p "  Press any key to return..."
}

# Stop cover traffic
cmd_cover_traffic_stop() {
    if [[ -f "$RUNTIME_DIR/cover_traffic.pid" ]]; then
        local pid
        pid=$(cat "$RUNTIME_DIR/cover_traffic.pid")
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null
            echo -e "${GREEN}✓${NC} Cover traffic stopped"
        fi
        rm -f "$RUNTIME_DIR/cover_traffic.pid"
    else
        echo -e "${YELLOW}No cover traffic running${NC}"
    fi
}

# Real-time Tor circuit performance monitor
cmd_monitor_circuits() {
    if ! check_ghost; then
        echo -e "${RED}Ghost is not running${NC}"
        return 1
    fi
    
    clear
    echo -e "${BOLD}=== TOR CIRCUIT MONITOR ===${NC}"
    echo ""
    echo -e "${DIM}Press Ctrl+C to exit${NC}"
    echo ""
    
    while true; do
        clear
        echo -e "${BOLD}=== TOR CIRCUIT MONITOR ===${NC}"
        echo -e "${DIM}Updated: $(date '+%Y-%m-%d %H:%M:%S')${NC}"
        echo ""
        
        # Get circuit status
        local circuit_info
        circuit_info=$(get_tor_info "GETINFO circuit-status")
        
        if [[ -n "$circuit_info" ]]; then
            echo -e "${CYAN}Active Circuits:${NC}"
            echo "$circuit_info" | grep "BUILT" | while read -r line; do
                local circuit_id path purpose
                circuit_id=$(echo "$line" | awk '{print $1}')
                path=$(echo "$line" | awk '{print $3}')
                purpose=$(echo "$line" | awk '{print $4}')
                
                echo -e "  Circuit $circuit_id: ${GREEN}BUILT${NC}"
                echo -e "    Path: $path"
                echo -e "    Purpose: $purpose"
                echo ""
            done
        fi
        
        # Get stream info
        local stream_info
        stream_info=$(get_tor_info "GETINFO stream-status")
        
        if [[ -n "$stream_info" ]]; then
            echo -e "${CYAN}Active Streams:${NC}"
            local stream_count
            stream_count=$(echo "$stream_info" | grep -c "SUCCEEDED" || echo 0)
            echo -e "  ${stream_count} active connections"
            echo ""
        fi
        
        # Get bandwidth
        local bw_info
        bw_info=$(get_tor_info "GETINFO traffic/read traffic/written")
        if [[ -n "$bw_info" ]]; then
            echo -e "${CYAN}Bandwidth:${NC}"
            local read_bytes written_bytes read_mb written_mb
            read_bytes=$(echo "$bw_info" | grep "traffic/read" | awk -F= '{print $2}')
            written_bytes=$(echo "$bw_info" | grep "traffic/written" | awk -F= '{print $2}')
            
            read_mb=$(( ${read_bytes:-0} / 1024 / 1024 ))
            written_mb=$(( ${written_bytes:-0} / 1024 / 1024 ))
            
            echo -e "  Downloaded: ${read_mb}MB"
            echo -e "  Uploaded: ${written_mb}MB"
            echo ""
        fi
        
        # Latency test
        echo -e "${CYAN}Latency Test:${NC}"
        local start end latency
        start=$(date +%s%N)
        timeout 3 curl -s https://check.torproject.org >/dev/null 2>&1
        end=$(date +%s%N)
        latency=$(( (end - start) / 1000000 ))
        
        if [[ $latency -lt 500 ]]; then
            echo -e "  ${GREEN}$latency ms (Fast)${NC}"
        elif [[ $latency -lt 2000 ]]; then
            echo -e "  ${YELLOW}$latency ms (Normal)${NC}"
        else
            echo -e "  ${RED}$latency ms (Slow)${NC}"
        fi
        
        sleep 3
    done
}

